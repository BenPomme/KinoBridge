{
  "name": "kinobridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "qa": "pnpm build && pnpm check && pnpm test",
    "dev:extension": "pnpm --filter @kinobridge/extension dev",
    "dev:helper": "pnpm --filter @kinobridge/native-helper dev",
    "diagnose": "pnpm --filter @kinobridge/native-helper diagnose",
    "package:macos": "bash scripts/package-macos.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.1.6",
    "@types/node": "^24.10.13",
    "esbuild": "^0.28.1",
    "tsx": "^4.21.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
