{
  "manifest_version": 3,
  "name": "KinoBridge",
  "description": "Open authorized Kino.pub HLS streams in a local media player.",
  "version": "0.1.0",
  "key": "",
  "minimum_chrome_version": "120",
  "permissions": ["storage", "tabs", "scripting", "webRequest", "nativeMessaging"],
  "host_permissions": [
    "https://kino.pub/*",
    "https://*.kino.pub/*",
    "https://zerkalo.xyz/*",
    "https://*.zerkalo.xyz/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open KinoBridge widget"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'"
  }
}
